{
    "character": {
        "card": "Shodan-specV2.json"
    },
    "prompt": {
        "template_file": "conversation_template.json"
    },
    "paths": {
        "persist_directory": "./character_storage/",
        "key_storage": "./rag_data/",
        "embedding_cache": "./embedding_models/",
        "documents_directory": "./rag_data/"
    },
    "embedding": {
        "device": "cpu",
        "model": "sentence-transformers/all-mpnet-base-v2"
    },
    "runtime": {
        "threads": 6
    },
    "model": {
        "path": "mistral_v0.1/mistral-7b-instruct-v0.1.Q4_K_M.gguf",
        "type": "mistral",
        "layers": "auto",
        "target_vram_usage": 0.8,
        "kv_cache_quant": "f16",
        "n_ctx": 32768,
        "n_batch": 256,
        "context": {
            "check": true,
            "auto_adjust": true
        }
    },
    "generation": {
        "temperature": 0.7,
        "top_p": 0.95,
        "repeat_penalty": 1.1,
        "top_k": 50,
        "last_n_tokens_size": 256,
        "max_tokens": 4096,
        "hard_max_tokens": 1024,
        "max_stream_chars": 2400,
        "max_silent_stream_chars": 120
    },
    "rag": {
        "collection": "shodan",
        "k": 3,
        "k_mes": 2,
        "fetch_k": 8,
        "score_threshold": 1.5,
        "use_mmr": true,
        "lambda_mult": 0.75,
        "rerank": {
            "enabled": true,
            "model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
            "top_n": 8
        },
        "multi_query": {
            "enabled": true,
            "max_variants": 3
        },
        "telemetry": {
            "enabled": false
        },
        "chunk_size": 900,
        "chunk_overlap": 180
    },
    "context": {
        "dynamic": {
            "enabled": true
        },
        "budget": {
            "reserved_for_response": 384
        },
        "history": {
            "min_turns": 2,
            "max_turns": 10,
            "summarization": {
                "enabled": true,
                "threshold_turns": 8,
                "keep_recent_turns": 6,
                "max_entries": 12,
                "max_chars_per_turn": 140
            }
        },
        "retrieval": {
            "chunk_size_estimate": 150,
            "max_initial_retrieval": 8,
            "max_vector_context_chars": 2200,
            "sentence_compression": {
                "enabled": true,
                "max_sentences": 8
            }
        }
    },
    "heuristics": {
        "small_talk_max_words": 8,
        "followup_rag_max_words": 12
    },
    "conversation_quality": {
        "persona_drift": {
            "enabled": true,
            "warning_threshold": 0.45,
            "fail_threshold": 0.65,
            "history_window": 20,
            "heuristic_weight": 0.6,
            "semantic_weight": 0.4
        }
    },
    "fallback": {
        "empty_stream": "I am unable to produce a visible response right now. Please try again.",
        "quality": "I will not repeat myself. Ask your question with more specificity."
    },
    "debug": {
        "prompt": false,
        "prompt_fingerprint": false,
        "context": false
    },
    "logging": {
        "level": "DEBUG",
        "show_logs": false,
        "to_file": true,
        "file": "./logs/light-chat.log"
    }
}